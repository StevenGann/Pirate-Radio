# Copy to .env and fill in. Never commit the real .env.
# These are read from the process environment at daemon startup. config.json
# references the *names* of the credential vars (e.g. api_key_env); the secrets
# themselves live here.

# --- Timezone (optional) ---
# Override the broadcast timezone with an IANA zone name. Normally unnecessary:
# the daemon resolves the system zone from /etc/timezone or /etc/localtime. Set
# this if those are missing/wrong (common on a minimal headless Pi) — otherwise
# the clock degrades to a fixed UTC offset and DST transitions are NOT tracked.
# PIRATE_RADIO_TZ=America/New_York

# --- LLM credentials (required only for the providers your config.json uses) ---
# The var NAME is referenced by each provider's api_key_env in config.json.
# A referenced var that is unset or empty fails fast at startup (A1).
# ANTHROPIC_API_KEY=sk-ant-...
# DEEPSEEK_API_KEY=...
# (Ollama needs no key — it's reached over HTTP.)

# --- TTS credentials (required only for cloud TTS backends) ---
# Referenced by tts_providers[*].api_key_env in config.json.
# ELEVENLABS_API_KEY=...

# --- Control API token (only if you enable the control block in config.json) ---
# The var NAME is control.token_env (default PIRATE_API_TOKEN). Generate a strong
# value, e.g. `openssl rand -hex 32`. See docs/ops/control-api.md.
# PIRATE_API_TOKEN=
